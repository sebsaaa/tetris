<Window x:Class="tetris2022.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tetris2022"
        mc:Ignorable="d"
        Title="Window1" Height="300" Width="460">
    <Window.Background>
        <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
            <GradientStop Color="#FF001052" Offset="0"/>
            <GradientStop Color="#FF001082" Offset="0.5"/>
            <GradientStop Color="#FF001052" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Viewbox>
        <Grid Width="287" Height="178">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="20,20,20,3" Grid.Column="0">
                <TextBlock Text="Red" Foreground="White" FontSize="20" FontFamily="pack://application:,,,/res/#Jersey 10"/>
                <Slider x:Name="RedSlider" Minimum="0" Maximum="255" ValueChanged="RGBSlider_ValueChanged"/>
                <TextBlock Text="Green" Foreground="White" FontSize="20" FontFamily="pack://application:,,,/res/#Jersey 10"/>
                <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" ValueChanged="RGBSlider_ValueChanged"/>
                <TextBlock Text="Blue" Foreground="White" FontSize="20" FontFamily="pack://application:,,,/res/#Jersey 10"/>
                <Slider x:Name="BlueSlider"  Minimum="0" Maximum="255" ValueChanged="RGBSlider_ValueChanged"/>


            </StackPanel>
            <Border x:Name="fill" Grid.Column="1" Margin="20,20,20,82" Background="Transparent" BorderThickness="2.5">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#004bb5" Offset="0"/>
                        <GradientStop Color="#2071aa" Offset="0.5"/>
                        <GradientStop Color="#004bb5" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
            <Border Grid.Column="1" Margin="20,113,19,0" BorderThickness="2" VerticalAlignment="Top" Background="#000a2e" Height="30" >
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#004bb5" Offset="0" />
                        <GradientStop Color="#2071aa" Offset="0.5"/>
                        <GradientStop Color="#004bb5" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Button x:Name="saveBtn" BorderBrush="Transparent" Background="Transparent" Content="        Save        " FontSize="20" FontFamily="pack://application:,,,/res/#Jersey 10" Foreground="White" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Click="save" />
            </Border>
        </Grid>
    </Viewbox>



</Window>
